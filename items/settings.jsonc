    // Progression
    {
        "name": "Progressive Warps",
        "type": "consumable",
        "img": "/images/settings/progressive_warps.png",
        "max_quantity": 15,
        "initial_quantity": 1,
        "codes": "progressive_warps"
    },
    {
        "name": "Level Unlock Method",
        "type": "progressive",
        "loop": true,
        "allow_disabled": false,
        "stages": [
            {
                "name": "Level Unlock Method (All Level Keys)",
                "img": "/images/settings/level_unlock_method_all_level_keys.png",
                "codes": "level_unlock_method,level_unlock_method_all_level_keys",
                "inherit_codes": false
            },
            {
                "name": "Level Unlock Method (One Level Key)",
                "img": "/images/settings/level_unlock_method_one_level_key.png",
                "codes": "level_unlock_method,level_unlock_method_one_level_key",
                "inherit_codes": false
            },
            {
                "name": "Level Unlock Method (One Progressive Warp)",
                "img": "/images/settings/level_unlock_method_one_progressive_warp.png",
                "codes": "level_unlock_method,level_unlock_method_one_progressive_warp",
                "inherit_codes": false
            }
        ]
    },
    {
        "name": "Progressive Weapon Ammo Upgrades",
        "type": "consumable",
        "img": "/images/settings/progressive_weapon_ammo_upgrades.png",
        "min_quantity": 1,
        "max_quantity": 5,
        "initial_quantity": 1,
        "codes": "progressive_weapon_ammo_upgrades"
    },

    // Tracker
    {
        "name": "Autofill Settings",
        "type": "toggle",
        "img": "/images/settings/autofill_settings.png",
        "initial_active_state": true,
        "codes": "autofill_settings"
    },

