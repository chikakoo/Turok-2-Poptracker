[
    // Goal
    {
        "name": "Level Goal",
        "type": "consumable",
        "img": "/images/settings/level_goal.png",
        "max_quantity": 6,
        "initial_quantity": 2,
        "codes": "level_goal"
    },
    {
        // Options are none, defeat, get to lair
        // Defeat and get to lair are logically equivalent here, so we can use a toggle
        "name": "Primagen Goal",
        "type": "toggle",
        "img": "/images/settings/primagen_goal.png",
        "initial_active_state": true,
        "codes": "primagen_goal"
    },

    // Included Levels
    {
        "name": "Include Level 1",
